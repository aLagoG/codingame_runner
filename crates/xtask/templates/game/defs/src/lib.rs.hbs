use std::{
    fmt::Display,
    io::{BufRead, Write},
    str::FromStr,
};

use bot_common::{ReadFrom, SingleLine, WriteTo};

/// Per-match init payload. Default to `()` (no init). If your game
/// ships per-player setup data before turn 1, replace the alias with
/// a struct + `Display`/`FromStr`/`SingleLine` impls — see
/// `fantastic_bits_defs::InitialInput` for a worked example.
pub type InitialInput = ();

// TODO: define your game's per-tick input fields. The engine
// constructs this; the bot's `decide(&TurnInput)` reads from it.
#[derive(Debug, Clone, Default)]
pub struct TurnInput {}

// TODO: define your game's per-tick output fields.
#[derive(Debug, Default, PartialEq, Eq, Copy, Clone)]
pub struct TurnOutput {}

// region: stdio wire format (Display / FromStr / ReadFrom / WriteTo)
//
// Subprocess bots talk over stdin/stdout, one tick at a time. Implement
// these to match the format your game uses. See `tron_defs` or
// `fantastic_bits_defs` for fully fleshed-out examples.

impl Display for TurnOutput {
    fn fmt(&self, _f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        Ok(())
    }
}

impl FromStr for TurnOutput {
    type Err = anyhow::Error;
    fn from_str(_s: &str) -> Result<Self, Self::Err> {
        Ok(TurnOutput::default())
    }
}

impl SingleLine for TurnOutput {}

impl ReadFrom for TurnInput {
    fn read_from(_r: &mut impl BufRead) -> anyhow::Result<Self> {
        Ok(TurnInput::default())
    }
}

impl WriteTo for TurnInput {
    fn write_to(&self, _w: &mut impl Write) -> std::io::Result<()> {
        Ok(())
    }
}
// endregion: stdio wire format
