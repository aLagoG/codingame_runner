use std::{
    fmt::Display,
    io::{BufRead, Write},
    marker::PhantomData,
    str::FromStr,
};

use common::{Defs, ReadFrom, SingleLine, TurnResult, WireInput, WireInputFfi, WireOutput, WriteTo};

/// Bumped on any wire-type change. Plugins built against an older
/// `{{name}}_defs` export an older value; `PluginPlayer::load` reads it and
/// refuses mismatches before any UB-prone call lands.
pub const ABI_VERSION: u32 = 1;

/// Marker type. Implementing [`common::Defs`] on it is the single line that
/// ratifies this crate's FFI surface — all of `WireInput`, `WireInputFfi`,
/// `WireOutput`, and `ABI_VERSION` are checked at this exact site.
pub struct Ffi;

impl Defs for Ffi {
    type Input = TurnInput;
    type Output = TurnOutput;
    const ABI_VERSION: u32 = ABI_VERSION;
}

// TODO: define your game's per-tick input fields. The engine constructs this;
// the bot's `decide(turn: TurnRef<'_>)` reads from it through `as_ref`.
#[derive(Debug, Clone, Default)]
pub struct TurnInput {}

/// Borrowed view of [`TurnInput`] — what `decide` actually sees.
pub struct TurnRef<'a> {
    _marker: PhantomData<&'a TurnInput>,
}

/// `#[repr(C)]` mirror of [`TurnInput`] for FFI. Fields are private — the only
/// constructor is `TurnInput::as_ffi`, which establishes the invariants
/// `as_ref` relies on.
#[repr(C)]
#[derive(Debug)]
pub struct TurnInputFFI<'a> {
    _marker: PhantomData<&'a TurnInput>,
}

// TODO: define your game's per-tick output fields.
#[repr(C)]
#[derive(Debug, Default, PartialEq, Eq, Copy, Clone, serde::Serialize, serde::Deserialize)]
pub struct TurnOutput {}

/// Asserts `TurnOutput` satisfies the full bundled contract — see
/// [`common::WireOutput`].
impl WireOutput for TurnOutput {}

// cbindgen reachability root — generates the `extern "C" { ... }` block in
// the C++ header. No symbols introduced into `_defs.rlib`; the real
// `take_turn` / `abi_version` are emitted by `common::ffi_bot!` in the bot
// crate. Keep in sync with that macro. `TurnResult` is generic over the
// per-game output; cbindgen monomorphises it into a concrete C++ struct.
unsafe extern "C" {
    pub fn take_turn(input: TurnInputFFI<'_>) -> TurnResult<TurnOutput>;
    pub fn abi_version() -> u32;
}

impl WireInput for TurnInput {
    type Ffi<'a> = TurnInputFFI<'a>;
    type Ref<'a> = TurnRef<'a>;

    fn as_ffi(&self) -> TurnInputFFI<'_> {
        TurnInputFFI { _marker: PhantomData }
    }

    fn as_ref(&self) -> TurnRef<'_> {
        TurnRef { _marker: PhantomData }
    }
}

impl<'a> WireInputFfi<'a> for TurnInputFFI<'a> {
    type Ref = TurnRef<'a>;

    /// Safe because every `TurnInputFFI<'a>` is constructed by `as_ffi`,
    /// which establishes the documented invariants.
    fn as_ref(&self) -> TurnRef<'a> {
        TurnRef { _marker: PhantomData }
    }
}

// region: stdio wire format (Display / FromStr / ReadFrom / WriteTo)
//
// Subprocess bots talk over stdin/stdout, one tick at a time. Implement
// these to match the format your game uses. See `tron_defs` or
// `tictactoe_defs` for fully fleshed-out examples.

impl Display for TurnOutput {
    fn fmt(&self, _f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        Ok(())
    }
}

impl FromStr for TurnOutput {
    type Err = anyhow::Error;
    fn from_str(_s: &str) -> Result<Self, Self::Err> {
        Ok(TurnOutput::default())
    }
}

impl SingleLine for TurnOutput {}

impl ReadFrom for TurnInput {
    fn read_from(_r: &mut impl BufRead) -> anyhow::Result<Self> {
        Ok(TurnInput::default())
    }
}

impl WriteTo for TurnInput {
    fn write_to(&self, _w: &mut impl Write) -> std::io::Result<()> {
        Ok(())
    }
}
// endregion: stdio wire format
