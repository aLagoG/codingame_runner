// C++ FFI bot for {{game}} ({{bot}} variant). Build + run via cargo
// from workspace root:
//
//   cargo build -p {{crate_name}}
//   cargo run -p codingame_runner -- --game {{game}} \
//       target/debug/lib{{crate_name}}.dylib \    # .so on Linux, .dll on Windows
//       target/debug/lib{{crate_name}}.dylib
//
// The four `extern "C"` exports below are the FFI contract — every bot
// must define `initialize`, `take_turn`, `abi_version`, and (optionally)
// `set_counter_callback`. Types come from the cbindgen-generated header.

#include "../../defs/include/{{game}}_defs.h"

static void (*g_emit_counter)(const char*, double) = nullptr;

extern "C" {

void set_counter_callback(void (*cb)(const char*, double)) {
    g_emit_counter = cb;
}

// Called once per player at match start. The default for new games is
// `NoInitialInputFfi` (no per-player data); when the game's defs
// defines a real `InitialInput`, change the param type to its FFI
// mirror (e.g. `InitialInputFFI`) and stash whatever you need in a
// static for `take_turn` to read.
void initialize(NoInitialInputFfi /*input*/) {}

// Called once per tick — return what your bot wants to play.
TurnResult<TurnOutput> take_turn(TurnInputFFI input) {
    (void)input;
    return TurnResult<TurnOutput>{
        /* status = */ BotStatus::Ok,
        /* output = */ TurnOutput{},
    };
}

// Must return the ABI version the bot was built against — the runner
// checks this on load and refuses mismatched plugins.
uint32_t abi_version() { return ABI_VERSION; }

}  // extern "C"
